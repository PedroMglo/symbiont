      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT round(vram_used_mb / 1024, 1) AS used_gb, round(vram_total_mb / 1024, 1) AS total_gb FROM ai_symbiont.resource_samples ORDER BY timestamp DESC LIMIT 1",
          "format": 1,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
