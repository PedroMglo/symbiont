        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT gpu_util_percent FROM ai_symbiont.resource_samples ORDER BY timestamp DESC LIMIT 1",
          "format": 1,
