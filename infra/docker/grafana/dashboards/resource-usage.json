    {
      "id": 16,
      "title": "Temperature",
      "type": "gauge",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 24 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT gpu_temperature_c FROM ai_symbiont.resource_samples ORDER BY timestamp DESC LIMIT 1",
          "format": 1,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 30,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 13,
      "title": "Mode",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 24 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT new_mode AS mode FROM ai_symbiont.adaptation_events WHERE event_type = 'degradation_change' ORDER BY timestamp DESC LIMIT 1",
          "format": 1,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "normal": { "text": "NORMAL", "color": "green" } }
            },
            {
              "type": "value",
              "options": {
                "constrained": { "text": "CONSTRAINED", "color": "yellow" }
              }
            },
            {
              "type": "value",
              "options": { "minimal": { "text": "MINIMAL", "color": "red" } }
            }
          ],
          "noValue": "NORMAL"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 8,
      "title": "VRAM Peaks During Requests",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 27 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT toStartOfInterval(timestamp, INTERVAL 10 second) AS time, max(vram_used_mb) AS vram_peak, avg(vram_used_mb) AS vram_avg FROM ai_symbiont.resource_samples WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY time ORDER BY time",
          "format": 2,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 9,
      "title": "Adaptation Events",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 27 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT timestamp AS time, multiIf(new_mode = 'minimal', 3, new_mode = 'constrained', 2, 1) AS severity, concat(event_type, ': ', prev_mode, ' \u2192 ', new_mode) AS label FROM ai_symbiont.adaptation_events WHERE timestamp >= $__fromTime AND timestamp <= $__toTime ORDER BY time",
          "format": 2,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "points", "pointSize": 8 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      }
    }
  ]
}
