{
  "uid": "orc-resources",
  "title": "AI Symbiont \u2014 Resource Usage",
  "tags": ["ai-symbiont", "resources"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "2s",
  "liveNow": true,
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["1s", "2s", "5s", "10s", "30s"],
    "time_options": ["1m", "5m", "15m", "30m", "1h", "6h"]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT timestamp AS time, cpu_percent FROM ai_symbiont.resource_samples WHERE timestamp >= $__fromTime AND timestamp <= $__toTime ORDER BY time",
          "format": 2,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "fixed", "fixedColor": "#73BF69" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true,
            "axisSoftMin": 0,
            "axisSoftMax": 100
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "id": 2,
      "title": "RAM Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT timestamp AS time, round(ram_used_mb / 1024, 2) AS used_gb, round(ram_total_mb / 1024, 2) AS total_gb FROM ai_symbiont.resource_samples WHERE timestamp >= $__fromTime AND timestamp <= $__toTime ORDER BY time",
          "format": 2,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total_gb" },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": { "fill": "dash", "dash": [8, 4] }
              },
              { "id": "custom.fillOpacity", "value": 0 },
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "used_gb" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "semi-dark-green" }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
