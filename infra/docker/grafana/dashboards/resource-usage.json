    {
      "id": 10,
      "title": "CPU",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 24 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT cpu_percent FROM ai_symbiont.resource_samples ORDER BY timestamp DESC LIMIT 1",
          "format": 1,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area"
      }
    },
    {
      "id": 11,
      "title": "RAM",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 24 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT round(ram_used_mb / 1024, 1) AS used_gb, round(ram_total_mb / 1024, 1) AS total_gb FROM ai_symbiont.resource_samples ORDER BY timestamp DESC LIMIT 1",
          "format": 1,
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decgbytes" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
