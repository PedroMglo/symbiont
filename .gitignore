# =============================================================================
# ai-local — Git Ignore (workspace root)
# =============================================================================

# -----------------------------------------------------------------------------
# Local environment, generated resolver outputs, and machine state
# -----------------------------------------------------------------------------
.env.storage.generated
.env.llm.generated
.env.services.generated
.env.docker.resources.generated
.env.llm-serving
.local/
reports/security/
.ai-local/
.tmp/
.storage_guardian_local/
.cache/
.direnv/

# -----------------------------------------------------------------------------
# Python build products, interpreter caches, package metadata
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
.venv*/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Editors, IDEs, and local workspace metadata
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Local Codex/agent guidance files
# -----------------------------------------------------------------------------
.codex/
.agents/
AGENTS.md

# -----------------------------------------------------------------------------
# Environment files, credentials, generated certificates, private config
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.*
!.env.example
config/private.local.yaml
config/private.local.yml
config/*.local.yaml
config/*.local.yml
infra/docker/.env
infra/docker/.env.*
infra/docker/secrets/*
!infra/docker/secrets/
!infra/docker/secrets/.gitignore
infra/gateway/certs/*
!infra/gateway/certs/
!infra/gateway/certs/.gitignore

